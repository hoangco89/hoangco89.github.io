[
    {
        "start": 1.439,
        "end": 13.28,
        "text": "Excuse me. Um, is this the entrance for international flights?",
        "textdich": ""
    },
    {
        "start": 9.84,
        "end": 19.76,
        "text": " Yes, this is the right entrance. Are you traveling today?",
        "textdich": ""
    },
    {
        "start": 15.12,
        "end": 30.48,
        "text": " Yes, I am flying to London. It is my first time flying alone, so I am a little nervous.",
        "textdich": ""
    },
    {
        "start": 26.8,
        "end": 39.04,
        "text": " Oh, do not worry at all. You will be fine. Do you have your passport and ticket?",
        "textdich": ""
    },
    {
        "start": 35.04,
        "end": 42.079,
        "text": " Yes, I do. Here they are.",
        "textdich": ""
    },
    {
        "start": 39.04,
        "end": 51.28,
        "text": " Great. You can go straight to the check-in counter. It is just over there.",
        "textdich": ""
    },
    {
        "start": 46.079,
        "end": 54.28,
        "text": " Oh, thank you. I always get confused in airports.",
        "textdich": ""
    },
    {
        "start": 54.719,
        "end": 61.68,
        "text": " Hello, ma'am. Good morning.",
        "textdich": ""
    },
    {
        "start": 58.079,
        "end": 66.479,
        "text": "May I see your passport?",
        "textdich": ""
    },
    {
        "start": 61.68,
        "end": 71.52,
        "text": " Good morning. Yes, here you go.",
        "textdich": ""
    },
    {
        "start": 66.479,
        "end": 77.68,
        "text": " Thank you. Are you checking in any bags today?",
        "textdich": ""
    },
    {
        "start": 72.96,
        "end": 82.159,
        "text": " Yes. This one big suitcase.",
        "textdich": ""
    },
    {
        "start": 77.68,
        "end": 88.32,
        "text": " Please place it on the scale.",
        "textdich": ""
    },
    {
        "start": 82.159,
        "end": 94.24,
        "text": " Sure. Oh, I hope it is not overweight.",
        "textdich": ""
    },
    {
        "start": 88.32,
        "end": 98.88,
        "text": " Let me check. You are fine. It is within the limit.",
        "textdich": ""
    },
    {
        "start": 95.92,
        "end": 104.24,
        "text": " Oh, thank God.",
        "textdich": ""
    },
    {
        "start": 98.88,
        "end": 107.36,
        "text": " Do you prefer a window seat or an aisle seat?",
        "textdich": ""
    },
    {
        "start": 105.6,
        "end": 116.64,
        "text": " H window seat, please. I like seeing the clouds.",
        "textdich": ""
    },
    {
        "start": 113.439,
        "end": 121.759,
        "text": "No problem. Here  is your boarding pass.",
        "textdich": ""
    },
    {
        "start": 118.96,
        "end": 126.159,
        "text": " Thank you so much.",
        "textdich": ""
    },
    {
        "start": 121.759,
        "end": 130.8,
        "text": " Your gate is B12.",
        "textdich": ""
    },
    {
        "start": 126.159,
        "end": 134.4,
        "text": "Boarding starts at 8:15.",
        "textdich": ""
    },
    {
        "start": 130.8,
        "end": 137.12,
        "text": " Sorry, can you repeat that?",
        "textdich": ""
    },
    {
        "start": 134.4,
        "end": 144.72,
        "text": " Gate B12, boarding at 8:15.",
        "textdich": ""
    },
    {
        "start": 141.2,
        "end": 149.04,
        "text": "Got it. Thank you.",
        "textdich": ""
    },
    {
        "start": 144.72,
        "end": 155.92,
        "text": " Ma'am, please put your laptop and phone in a separate tray.",
        "textdich": ""
    },
    {
        "start": 151.76,
        "end": 160.48,
        "text": " Oh, okay. Everything except my passport, right?",
        "textdich": ""
    },
    {
        "start": 156.8,
        "end": 170.72,
        "text": " Yes, you can keep your passport with you. And please remove your belt and watch.",
        "textdich": ""
    },
    {
        "start": 165.92,
        "end": 178.0,
        "text": " Belt also. Oh, okay. Sure. Please walk through the scanner  like this.",
        "textdich": ""
    },
    {
        "start": 174.239,
        "end": 181.519,
        "text": " Yes, go ahead.",
        "textdich": ""
    },
    {
        "start": 178.0,
        "end": 185.92,
        "text": " Oh no. Why is it beeping?",
        "textdich": ""
    },
    {
        "start": 181.519,
        "end": 190.4,
        "text": " Do not worry. Maybe it is your keys.",
        "textdich": ""
    },
    {
        "start": 185.92,
        "end": 194.879,
        "text": " Oh yes, I forgot. Let me put them in the tray.",
        "textdich": ""
    },
    {
        "start": 191.28,
        "end": 197.599,
        "text": " Perfect. Try again.",
        "textdich": ""
    },
    {
        "start": 194.879,
        "end": 201.36,
        "text": "You are good to go.",
        "textdich": ""
    },
    {
        "start": 197.599,
        "end": 204.8,
        "text": "Thank you. Airports stress me out.",
        "textdich": ""
    },
    {
        "start": 201.36,
        "end": 207.2,
        "text": " It happens to everyone.",
        "textdich": ""
    },
    {
        "start": 204.8,
        "end": 211.12,
        "text": " Excuse me. Can you tell me where gate B12 is?",
        "textdich": ""
    },
    {
        "start": 208.879,
        "end": 215.44,
        "text": " Yes. Just walk straight and then turn left. You will see the sign.",
        "textdich": ""
    },
    {
        "start": 213.519,
        "end": 218.72,
        "text": " Straight and then left.",
        "textdich": ""
    },
    {
        "start": 215.44,
        "end": 221.2,
        "text": " Yes, it is about a 5-minute walk.",
        "textdich": ""
    },
    {
        "start": 218.72,
        "end": 224.959,
        "text": " Thank you so much.",
        "textdich": ""
    },
    {
        "start": 221.2,
        "end": 228.4,
        "text": " Hi, is this gate B12?",
        "textdich": ""
    },
    {
        "start": 224.959,
        "end": 231.44,
        "text": " Yes, it is. Are you flying to London?",
        "textdich": ""
    },
    {
        "start": 228.4,
        "end": 234.239,
        "text": " Yes. Is the flight on time?",
        "textdich": ""
    },
    {
        "start": 231.44,
        "end": 237.12,
        "text": " Yes, everything is on schedule.",
        "textdich": ""
    },
    {
        "start": 234.239,
        "end": 240.159,
        "text": " Good. I was worried because of the weather.",
        "textdich": ""
    },
    {
        "start": 238.159,
        "end": 244.319,
        "text": " Do not worry. The weather looks fine now.",
        "textdich": ""
    },
    {
        "start": 240.959,
        "end": 247.36,
        "text": " Great. Thank you.",
        "textdich": ""
    },
    {
        "start": 244.319,
        "end": 251.599,
        "text": " Good evening. Can I see your boarding pass, please?",
        "textdich": ""
    },
    {
        "start": 249.28,
        "end": 254.72,
        "text": " Yes, here it is.",
        "textdich": ""
    },
    {
        "start": 251.599,
        "end": 261.68,
        "text": " Thank you. Please follow the line and board through the front door.",
        "textdich": ""
    },
    {
        "start": 258.0,
        "end": 266.96,
        "text": " Okay. Um, is this the right time? I am always scared of boarding late.",
        "textdich": ""
    },
    {
        "start": 264.0,
        "end": 271.44,
        "text": " You are perfectly on time.",
        "textdich": ""
    },
    {
        "start": 266.96,
        "end": 276.0,
        "text": " Oh, nice. Thank you.",
        "textdich": ""
    },
    {
        "start": 271.44,
        "end": 280.8,
        "text": " Hello, ma'am. Welcome aboard. Your seat is 21A.",
        "textdich": ""
    },
    {
        "start": 279.199,
        "end": 282.639,
        "text": " 21A.",
        "textdich": ""
    },
    {
        "start": 280.8,
        "end": 286.88,
        "text": "Is that on the left?",
        "textdich": ""
    },
    {
        "start": 282.639,
        "end": 290.24,
        "text": " Yes, left side by the window.",
        "textdich": ""
    },
    {
        "start": 286.88,
        "end": 292.88,
        "text": " Perfect. I love window seats.",
        "textdich": ""
    },
    {
        "start": 290.24,
        "end": 294.24,
        "text": " Please fasten your seat belt.",
        "textdich": ""
    },
    {
        "start": 292.88,
        "end": 298.16,
        "text": " Like this.",
        "textdich": ""
    },
    {
        "start": 294.24,
        "end": 300.0,
        "text": " Yes. Pull it tight. Great.",
        "textdich": ""
    },
    {
        "start": 298.16,
        "end": 303.28,
        "text": " When do we take off?",
        "textdich": ""
    },
    {
        "start": 300.0,
        "end": 306.4,
        "text": " In about 20 minutes.",
        "textdich": ""
    },
    {
        "start": 303.28,
        "end": 310.56,
        "text": " Okay. Thank you.",
        "textdich": ""
    },
    {
        "start": 306.4,
        "end": 326.639,
        "text": " Excuse me. Can I ask something? Of course, ma'am. How can I help? Um, I have never flown long distance. What if I feel sick? Do not worry. We have",
        "textdich": ""
    },
    {
        "start": 322.88,
        "end": 340.08,
        "text": "water, medicine, and sick bags, and I am here to help you. Oh, thank you. I feel better now.",
        "textdich": ""
    },
    {
        "start": 334.8,
        "end": 343.759,
        "text": "Excuse me. Sorry to bother you again.",
        "textdich": ""
    },
    {
        "start": 340.08,
        "end": 352.08,
        "text": "No, it is okay. Tell me,  is there vegetarian food?",
        "textdich": ""
    },
    {
        "start": 347.28,
        "end": 357.759,
        "text": " Yes, we have a vegetarian option. Would you like that?",
        "textdich": ""
    },
    {
        "start": 353.919,
        "end": 360.8,
        "text": " Yes, please. Thank you so much.",
        "textdich": ""
    },
    {
        "start": 357.759,
        "end": 368.24,
        "text": " Ladies and gentlemen, welcome to London.",
        "textdich": ""
    },
    {
        "start": 360.8,
        "end": 369.759,
        "text": "Local time is 2:45 p.m. Wow, finally.",
        "textdich": ""
    },
    {
        "start": 368.24,
        "end": 371.199,
        "text": "Passport, please.",
        "textdich": ""
    },
    {
        "start": 369.759,
        "end": 373.759,
        "text": " Here you go.",
        "textdich": ""
    },
    {
        "start": 371.199,
        "end": 376.96,
        "text": " What is the purpose of your visit?",
        "textdich": ""
    },
    {
        "start": 373.759,
        "end": 378.72,
        "text": " Tourism. Just a short trip.",
        "textdich": ""
    },
    {
        "start": 376.96,
        "end": 380.24,
        "text": " How many days?",
        "textdich": ""
    },
    {
        "start": 378.72,
        "end": 382.08,
        "text": " 7 days.",
        "textdich": ""
    },
    {
        "start": 380.24,
        "end": 385.12,
        "text": " Where will you stay?",
        "textdich": ""
    },
    {
        "start": 382.08,
        "end": 386.96,
        "text": " At a hotel in central London.",
        "textdich": ""
    },
    {
        "start": 385.12,
        "end": 390.199,
        "text": " Okay. Enjoy your trip.",
        "textdich": ""
    },
    {
        "start": 386.96,
        "end": 390.199,
        "text": " Thank you.",
        "textdich": ""
    }

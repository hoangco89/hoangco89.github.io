[
  {
    "start": 0.24,
    "end": 4.24,
    "text": "Bị táo bón kéo dài, người đàn ông 69",
    "textdich": ""
  },
  {
    "start": 2.55,
    "end": 4.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 2.56,
    "end": 6.24,
    "text": "tuổi phát hiện cùng lúc hai loại ung thư",
    "textdich": ""
  },
  {
    "start": 4.23,
    "end": 6.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 4.24,
    "end": 8.48,
    "text": "tiêu hóa. Liên tục bị táo bón trong thời",
    "textdich": ""
  },
  {
    "start": 6.23,
    "end": 8.48,
    "text": "",
    "textdich": ""
  },
  {
    "start": 6.24,
    "end": 10.4,
    "text": "gian dài, người đàn ông 69 tuổi đến khám",
    "textdich": ""
  },
  {
    "start": 8.47,
    "end": 10.4,
    "text": "",
    "textdich": ""
  },
  {
    "start": 8.48,
    "end": 12.04,
    "text": "tại bệnh viện Việt Nam thị điển Uô Bí và",
    "textdich": ""
  },
  {
    "start": 10.39,
    "end": 12.04,
    "text": "",
    "textdich": ""
  },
  {
    "start": 10.4,
    "end": 13.96,
    "text": "bất ngờ được phát hiện mắt đồng thời hai",
    "textdich": ""
  },
  {
    "start": 12.03,
    "end": 13.96,
    "text": "",
    "textdich": ""
  },
  {
    "start": 12.04,
    "end": 15.44,
    "text": "bệnh lý ung thư tiêu hóa giai đoạn sớm.",
    "textdich": ""
  },
  {
    "start": 13.95,
    "end": 15.44,
    "text": "",
    "textdich": ""
  },
  {
    "start": 13.96,
    "end": 17.08,
    "text": "Qua nội soi tiêu hóa, các bác sĩ phát",
    "textdich": ""
  },
  {
    "start": 15.43,
    "end": 17.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 15.44,
    "end": 19.439,
    "text": "hiện người bệnh bị ung thư dạ dày giai",
    "textdich": ""
  },
  {
    "start": 17.07,
    "end": 19.439,
    "text": "",
    "textdich": ""
  },
  {
    "start": 17.08,
    "end": 21.32,
    "text": "đoạn sớm và một poli đại tràng đã chuyển",
    "textdich": ""
  },
  {
    "start": 19.429,
    "end": 21.32,
    "text": "",
    "textdich": ""
  },
  {
    "start": 19.439,
    "end": 23.039,
    "text": "thành ung thư cũng mở giai đoạn sớm.",
    "textdich": ""
  },
  {
    "start": 21.31,
    "end": 23.039,
    "text": "",
    "textdich": ""
  },
  {
    "start": 21.32,
    "end": 25.24,
    "text": "Điều đáng chú ý là cả hai tổn thương đều",
    "textdich": ""
  },
  {
    "start": 23.029,
    "end": 25.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 23.039,
    "end": 27.08,
    "text": "còn khu trú chưa xâm lấn hay di căn giúp",
    "textdich": ""
  },
  {
    "start": 25.23,
    "end": 27.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 25.24,
    "end": 28.8,
    "text": "mở ra cơ hội điều trị chủ động với",
    "textdich": ""
  },
  {
    "start": 27.07,
    "end": 28.8,
    "text": "",
    "textdich": ""
  },
  {
    "start": 27.08,
    "end": 30.48,
    "text": "phương pháp ít xâm lớn hơn. Sau hội",
    "textdich": ""
  },
  {
    "start": 28.79,
    "end": 30.48,
    "text": "",
    "textdich": ""
  },
  {
    "start": 28.8,
    "end": 32.32,
    "text": "chẫn, ekip điều trị quyết định can thiệp",
    "textdich": ""
  },
  {
    "start": 30.47,
    "end": 32.32,
    "text": "",
    "textdich": ""
  },
  {
    "start": 30.48,
    "end": 34.12,
    "text": "bằng kỹ thuật các tách dưới niêm mạc qua",
    "textdich": ""
  },
  {
    "start": 32.31,
    "end": 34.12,
    "text": "",
    "textdich": ""
  },
  {
    "start": 32.32,
    "end": 36.04,
    "text": "nội soi. Đây là phương pháp cho phép",
    "textdich": ""
  },
  {
    "start": 34.11,
    "end": 36.04,
    "text": "",
    "textdich": ""
  },
  {
    "start": 34.12,
    "end": 37.96,
    "text": "loại bỏ tổn thương ngay từ lớp niêm mạc",
    "textdich": ""
  },
  {
    "start": 36.03,
    "end": 37.96,
    "text": "",
    "textdich": ""
  },
  {
    "start": 36.04,
    "end": 39.76,
    "text": "và dưới niêm mạc của ống tiêu hóa mà",
    "textdich": ""
  },
  {
    "start": 37.95,
    "end": 39.76,
    "text": "",
    "textdich": ""
  },
  {
    "start": 37.96,
    "end": 41.559,
    "text": "không cần phải phẫu thuật mỡ. Trong",
    "textdich": ""
  },
  {
    "start": 39.75,
    "end": 41.559,
    "text": "",
    "textdich": ""
  },
  {
    "start": 39.76,
    "end": 43.52,
    "text": "trường hợp này, toàn bộ tổn thương ở cả",
    "textdich": ""
  },
  {
    "start": 41.549,
    "end": 43.52,
    "text": "",
    "textdich": ""
  },
  {
    "start": 41.559,
    "end": 45.559,
    "text": "dạ dày và đại tràng được xử lý chỉ trong",
    "textdich": ""
  },
  {
    "start": 43.51,
    "end": 45.559,
    "text": "",
    "textdich": ""
  },
  {
    "start": 43.52,
    "end": 47.039,
    "text": "một lần nội soi. Nhờ phát hiện sớm và",
    "textdich": ""
  },
  {
    "start": 45.549,
    "end": 47.039,
    "text": "",
    "textdich": ""
  },
  {
    "start": 45.559,
    "end": 48.719,
    "text": "can thiệp đúng thời điểm, người bệnh",
    "textdich": ""
  },
  {
    "start": 47.029,
    "end": 48.719,
    "text": "",
    "textdich": ""
  },
  {
    "start": 47.039,
    "end": 50.64,
    "text": "không phải trải qua phẫu thuật lớn cũng",
    "textdich": ""
  },
  {
    "start": 48.709,
    "end": 50.64,
    "text": "",
    "textdich": ""
  },
  {
    "start": 48.719,
    "end": 52.559,
    "text": "không cần hóa trị hay xạ trị. Quá trình",
    "textdich": ""
  },
  {
    "start": 50.63,
    "end": 52.559,
    "text": "",
    "textdich": ""
  },
  {
    "start": 50.64,
    "end": 54.52,
    "text": "điều trị vì vậy nhẹ nhàng hơn, thời gian",
    "textdich": ""
  },
  {
    "start": 52.549,
    "end": 54.52,
    "text": "",
    "textdich": ""
  },
  {
    "start": 52.559,
    "end": 56.16,
    "text": "hồi phục nhanh hơn và giảm đáng kể nguy",
    "textdich": ""
  },
  {
    "start": 54.51,
    "end": 56.16,
    "text": "",
    "textdich": ""
  },
  {
    "start": 54.52,
    "end": 58.0,
    "text": "cơ biến chứng so với điều trị ung thư",
    "textdich": ""
  },
  {
    "start": 56.15,
    "end": 58.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 56.16,
    "end": 60.0,
    "text": "giai đoạn muồn. Ung thư dạ dày là tình",
    "textdich": ""
  },
  {
    "start": 57.99,
    "end": 60.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 58.0,
    "end": 61.48,
    "text": "trạng các lớp tế bào ở niêm mạc dạ dày",
    "textdich": ""
  },
  {
    "start": 59.99,
    "end": 61.48,
    "text": "",
    "textdich": ""
  },
  {
    "start": 60.0,
    "end": 63.68,
    "text": "tăng sinh bất thường, dần hình thành",
    "textdich": ""
  },
  {
    "start": 61.47,
    "end": 63.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 61.48,
    "end": 65.72,
    "text": "khối u và có thể xâm lấn sâu vào thành",
    "textdich": ""
  },
  {
    "start": 63.67,
    "end": 65.72,
    "text": "",
    "textdich": ""
  },
  {
    "start": 63.68,
    "end": 67.28,
    "text": "dạ dày hoặc lan sang cơ quan khác nếu",
    "textdich": ""
  },
  {
    "start": 65.71,
    "end": 67.28,
    "text": "",
    "textdich": ""
  },
  {
    "start": 65.72,
    "end": 69.08,
    "text": "không được phát hiện sớm. Bình thường",
    "textdich": ""
  },
  {
    "start": 67.27,
    "end": 69.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 67.28,
    "end": 71.08,
    "text": "tiến triển âm thầm, các dấu hiệu ban đầu",
    "textdich": ""
  },
  {
    "start": 69.07,
    "end": 71.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 69.08,
    "end": 73.24,
    "text": "như đầy bụng, chán ăn, khó tiêu hoặc sục",
    "textdich": ""
  },
  {
    "start": 71.07,
    "end": 73.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 71.08,
    "end": 75.0,
    "text": "cơn rất dễ bị bỏ qua. Trong khi đó, ung",
    "textdich": ""
  },
  {
    "start": 73.23,
    "end": 75.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 73.24,
    "end": 76.92,
    "text": "thư đại tràng phần lớn khởi phát cho các",
    "textdich": ""
  },
  {
    "start": 74.99,
    "end": 76.92,
    "text": "",
    "textdich": ""
  },
  {
    "start": 75.0,
    "end": 78.6,
    "text": "polip, những khối tăng sinh nhỏ niêm mạc",
    "textdich": ""
  },
  {
    "start": 76.91,
    "end": 78.6,
    "text": "",
    "textdich": ""
  },
  {
    "start": 76.92,
    "end": 80.439,
    "text": "ruột. Nhiều polyp ban đầu lành tính",
    "textdich": ""
  },
  {
    "start": 78.59,
    "end": 80.439,
    "text": "",
    "textdich": ""
  },
  {
    "start": 78.6,
    "end": 82.36,
    "text": "nhưng nếu tồn tại lâu năm có thể chuyển",
    "textdich": ""
  },
  {
    "start": 80.429,
    "end": 82.36,
    "text": "",
    "textdich": ""
  },
  {
    "start": 80.439,
    "end": 83.799,
    "text": "thành ung thư. Ở giai đoạn sớm, bệnh có",
    "textdich": ""
  },
  {
    "start": 82.35,
    "end": 83.799,
    "text": "",
    "textdich": ""
  },
  {
    "start": 82.36,
    "end": 85.56,
    "text": "thể chỉ biểu hiện bằng rối loạn tiêu",
    "textdich": ""
  },
  {
    "start": 83.789,
    "end": 85.56,
    "text": "",
    "textdich": ""
  },
  {
    "start": 83.799,
    "end": 87.799,
    "text": "hóa, táo bón hoặc thay đổi thói quen đi",
    "textdich": ""
  },
  {
    "start": 85.55,
    "end": 87.799,
    "text": "",
    "textdich": ""
  },
  {
    "start": 85.56,
    "end": 89.6,
    "text": "ngoài nên dễ bị xem nhẹ. Nhiều yếu tố",
    "textdich": ""
  },
  {
    "start": 87.789,
    "end": 89.6,
    "text": "",
    "textdich": ""
  },
  {
    "start": 87.799,
    "end": 91.4,
    "text": "làm tăng nguy cơ ung thư tiêu hóa. Theo",
    "textdich": ""
  },
  {
    "start": 89.59,
    "end": 91.4,
    "text": "",
    "textdich": ""
  },
  {
    "start": 89.6,
    "end": 93.0,
    "text": "các chuyên gia, ung thư dạ dày và đại",
    "textdich": ""
  },
  {
    "start": 91.39,
    "end": 93.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 91.4,
    "end": 95.399,
    "text": "tràng có nhiều yếu tố nguy cơ chung.",
    "textdich": ""
  },
  {
    "start": 92.99,
    "end": 95.399,
    "text": "",
    "textdich": ""
  },
  {
    "start": 93.0,
    "end": 96.68,
    "text": "Nhiễm vi khuẩn Helicobactory được xem là",
    "textdich": ""
  },
  {
    "start": 95.389,
    "end": 96.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 95.399,
    "end": 98.72,
    "text": "một trong những nguyên nhân quan trọng",
    "textdich": ""
  },
  {
    "start": 96.67,
    "end": 98.72,
    "text": "",
    "textdich": ""
  },
  {
    "start": 96.68,
    "end": 100.6,
    "text": "gây ra ung thư dạ dày. Ngoài ra, chế độ",
    "textdich": ""
  },
  {
    "start": 98.71,
    "end": 100.6,
    "text": "",
    "textdich": ""
  },
  {
    "start": 98.72,
    "end": 102.399,
    "text": "ăn nhiều muối, thực phẩm ướp, hung khói",
    "textdich": ""
  },
  {
    "start": 100.59,
    "end": 102.399,
    "text": "",
    "textdich": ""
  },
  {
    "start": 100.6,
    "end": 104.04,
    "text": "hoặc nướng ở nhiệt độ cao cũng có thể",
    "textdich": ""
  },
  {
    "start": 102.389,
    "end": 104.04,
    "text": "",
    "textdich": ""
  },
  {
    "start": 102.399,
    "end": 105.68,
    "text": "làm tăng nguy cơ tổn thương đi mạc đường",
    "textdich": ""
  },
  {
    "start": 104.03,
    "end": 105.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 104.04,
    "end": 107.64,
    "text": "tiêu hóa. Các thói quen như hút thuốc",
    "textdich": ""
  },
  {
    "start": 105.67,
    "end": 107.64,
    "text": "",
    "textdich": ""
  },
  {
    "start": 105.68,
    "end": 109.719,
    "text": "lá, uống rượu, bia ít vận động, thừa cơn",
    "textdich": ""
  },
  {
    "start": 107.63,
    "end": 109.719,
    "text": "",
    "textdich": ""
  },
  {
    "start": 107.64,
    "end": 111.479,
    "text": "béo phì và tiền sử gia đình có người mát",
    "textdich": ""
  },
  {
    "start": 109.709,
    "end": 111.479,
    "text": "",
    "textdich": ""
  },
  {
    "start": 109.719,
    "end": 113.2,
    "text": "ung thư tiêu hóa cũng góp phần làm tăng",
    "textdich": ""
  },
  {
    "start": 111.469,
    "end": 113.2,
    "text": "",
    "textdich": ""
  },
  {
    "start": 111.479,
    "end": 115.24,
    "text": "nguy cơ mắc bệnh. Bên cạnh đó, tình",
    "textdich": ""
  },
  {
    "start": 113.19,
    "end": 115.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 113.2,
    "end": 117.0,
    "text": "trạng vi mãn tính kéo dài ở dạ dày hoặc",
    "textdich": ""
  },
  {
    "start": 115.23,
    "end": 117.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 115.24,
    "end": 118.6,
    "text": "đại trang có thể tạo điều kiện cho tế",
    "textdich": ""
  },
  {
    "start": 116.99,
    "end": 118.6,
    "text": "",
    "textdich": ""
  },
  {
    "start": 117.0,
    "end": 120.119,
    "text": "bào ác tính hình thành. Để phòng ngừa,",
    "textdich": ""
  },
  {
    "start": 118.59,
    "end": 120.119,
    "text": "",
    "textdich": ""
  },
  {
    "start": 118.6,
    "end": 122.039,
    "text": "các bác sĩ khuyến cáo người dân nên duy",
    "textdich": ""
  },
  {
    "start": 120.109,
    "end": 122.039,
    "text": "",
    "textdich": ""
  },
  {
    "start": 120.119,
    "end": 124.079,
    "text": "trì chế độ ăn dàu, rau xanh, trái cây và",
    "textdich": ""
  },
  {
    "start": 122.029,
    "end": 124.079,
    "text": "",
    "textdich": ""
  },
  {
    "start": 122.039,
    "end": 126.24,
    "text": "chất xơ. Hạn chế thịt đỏ, thực phẩm chế",
    "textdich": ""
  },
  {
    "start": 124.069,
    "end": 126.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 124.079,
    "end": 128.16,
    "text": "biến sẵn và các món nướng nhiều khói.",
    "textdich": ""
  },
  {
    "start": 126.23,
    "end": 128.16,
    "text": "",
    "textdich": ""
  },
  {
    "start": 126.24,
    "end": 130.08,
    "text": "Cùng với đó là bỏ thuốc lá, hạn chế rượu",
    "textdich": ""
  },
  {
    "start": 128.15,
    "end": 130.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 128.16,
    "end": 133.479,
    "text": "bia, kiểm soát cân nặng và duy trì vận",
    "textdich": ""
  },
  {
    "start": 130.07,
    "end": 133.479,
    "text": "",
    "textdich": ""
  },
  {
    "start": 130.08,
    "end": 133.479,
    "text": "động thường xuyên.",
    "textdich": ""
  }
]
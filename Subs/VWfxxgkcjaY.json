  },
  {
    "start": 875.279,
    "end": 880.0,
    "text": "early.",
    "textdich": ""
  },
  {
    "start": 876.32,
    "end": 883.519,
    "text": " I won't. So, let me say it all one more",
    "textdich": ""
  },
  {
    "start": 880.0,
    "end": 887.199,
    "text": "time. I take the medicine twice a day",
    "textdich": ""
  },

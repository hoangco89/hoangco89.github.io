[
  {
    "start": 0.32,
    "end": 4.759,
    "text": "Buổi tối lên tập thể dục gì là tốt nhất?",
    "textdich": ""
  },
  {
    "start": 2.629,
    "end": 4.759,
    "text": "",
    "textdich": ""
  },
  {
    "start": 2.639,
    "end": 7.08,
    "text": "Bác sĩ tiết nộ sự thật khiến nhiều người",
    "textdich": ""
  },
  {
    "start": 4.749,
    "end": 7.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 4.759,
    "end": 8.96,
    "text": "sửng sốt. Buổi tối trước khi đi ngủ đấy",
    "textdich": ""
  },
  {
    "start": 7.07,
    "end": 8.96,
    "text": "",
    "textdich": ""
  },
  {
    "start": 7.08,
    "end": 11.04,
    "text": "thì các cô chú anh chị thường làm gì?",
    "textdich": ""
  },
  {
    "start": 8.95,
    "end": 11.04,
    "text": "",
    "textdich": ""
  },
  {
    "start": 8.96,
    "end": 13.08,
    "text": "Đánh răng giữa mặt, nằm nướt điện thoại",
    "textdich": ""
  },
  {
    "start": 11.03,
    "end": 13.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 11.04,
    "end": 14.519,
    "text": "một lát rồi thiếp đi. Và cháu Tuấn nói",
    "textdich": ""
  },
  {
    "start": 13.07,
    "end": 14.519,
    "text": "",
    "textdich": ""
  },
  {
    "start": 13.08,
    "end": 16.279,
    "text": "thật đây không phải là những các cái",
    "textdich": ""
  },
  {
    "start": 14.509,
    "end": 16.279,
    "text": "",
    "textdich": ""
  },
  {
    "start": 14.519,
    "end": 18.08,
    "text": "điều quan trọng nhất đâu ạ. Và cái điều",
    "textdich": ""
  },
  {
    "start": 16.269,
    "end": 18.08,
    "text": "",
    "textdich": ""
  },
  {
    "start": 16.279,
    "end": 20.16,
    "text": "quyết định tới sức khỏe, tuổi thọ và cái",
    "textdich": ""
  },
  {
    "start": 18.07,
    "end": 20.16,
    "text": "",
    "textdich": ""
  },
  {
    "start": 18.08,
    "end": 21.88,
    "text": "sự vững vàng của đôi chân về già nằm ở",
    "textdich": ""
  },
  {
    "start": 20.15,
    "end": 21.88,
    "text": "",
    "textdich": ""
  },
  {
    "start": 20.16,
    "end": 24.039,
    "text": "một cái khoảng thời gian rất là ngắn",
    "textdich": ""
  },
  {
    "start": 21.87,
    "end": 24.039,
    "text": "",
    "textdich": ""
  },
  {
    "start": 21.88,
    "end": 26.88,
    "text": "nhưng hầu như ai cũng bỏ lỡ. Vậy thì",
    "textdich": ""
  },
  {
    "start": 24.029,
    "end": 26.88,
    "text": "",
    "textdich": ""
  },
  {
    "start": 24.039,
    "end": 29.119,
    "text": "chúng ta nên tập gì? Động tác một đó là",
    "textdich": ""
  },
  {
    "start": 26.87,
    "end": 29.119,
    "text": "",
    "textdich": ""
  },
  {
    "start": 26.88,
    "end": 31.56,
    "text": "chúng ta sẽ chấp tay, mỡ ngực, khai",
    "textdich": ""
  },
  {
    "start": 29.109,
    "end": 31.56,
    "text": "",
    "textdich": ""
  },
  {
    "start": 29.119,
    "end": 33.2,
    "text": "thông hơi thở, giảm stress buổi tối.",
    "textdich": ""
  },
  {
    "start": 31.55,
    "end": 33.2,
    "text": "",
    "textdich": ""
  },
  {
    "start": 31.56,
    "end": 35.0,
    "text": "Cháu Tuấn muốn chia sẻ lại điều này từ",
    "textdich": ""
  },
  {
    "start": 33.19,
    "end": 35.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 33.2,
    "end": 36.84,
    "text": "các cái bậc tiền bối trong dưỡng sinh.",
    "textdich": ""
  },
  {
    "start": 34.99,
    "end": 36.84,
    "text": "",
    "textdich": ""
  },
  {
    "start": 35.0,
    "end": 38.719,
    "text": "Chỉ cần chúng ta làm đều đấy khoảng 60",
    "textdich": ""
  },
  {
    "start": 36.83,
    "end": 38.719,
    "text": "",
    "textdich": ""
  },
  {
    "start": 36.84,
    "end": 40.84,
    "text": "lần mỗi tối thì thể trạng của các cô",
    "textdich": ""
  },
  {
    "start": 38.709,
    "end": 40.84,
    "text": "",
    "textdich": ""
  },
  {
    "start": 38.719,
    "end": 43.28,
    "text": "chú, anh chị đã vượt xa một nửa số người",
    "textdich": ""
  },
  {
    "start": 40.83,
    "end": 43.28,
    "text": "",
    "textdich": ""
  },
  {
    "start": 40.84,
    "end": 45.76,
    "text": "cùng tụi. Động tác này sẽ giúp mỡ rộng",
    "textdich": ""
  },
  {
    "start": 43.27,
    "end": 45.76,
    "text": "",
    "textdich": ""
  },
  {
    "start": 43.28,
    "end": 47.8,
    "text": "nồng ngực, tăng cái lượng oxy vào phổi,",
    "textdich": ""
  },
  {
    "start": 45.75,
    "end": 47.8,
    "text": "",
    "textdich": ""
  },
  {
    "start": 45.76,
    "end": 49.879,
    "text": "giảm gánh nặng cho tim. Các cô chú, anh",
    "textdich": ""
  },
  {
    "start": 47.79,
    "end": 49.879,
    "text": "",
    "textdich": ""
  },
  {
    "start": 47.8,
    "end": 51.68,
    "text": "chị sẽ đứng thẳng và chúng ta sẽ dùng",
    "textdich": ""
  },
  {
    "start": 49.869,
    "end": 51.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 49.879,
    "end": 53.32,
    "text": "hai tay chúng ta chấp lại trước ngực.",
    "textdich": ""
  },
  {
    "start": 51.67,
    "end": 53.32,
    "text": "",
    "textdich": ""
  },
  {
    "start": 51.68,
    "end": 54.96,
    "text": "Sau đó thì chúng ta sẽ mở rộng ra hai",
    "textdich": ""
  },
  {
    "start": 53.31,
    "end": 54.96,
    "text": "",
    "textdich": ""
  },
  {
    "start": 53.32,
    "end": 56.559,
    "text": "bên.",
    "textdich": ""
  },
  {
    "start": 54.95,
    "end": 56.559,
    "text": "",
    "textdich": ""
  },
  {
    "start": 54.96,
    "end": 58.48,
    "text": "Khi mà làm như vậy đấy thì các cô chú",
    "textdich": ""
  },
  {
    "start": 56.549,
    "end": 58.48,
    "text": "",
    "textdich": ""
  },
  {
    "start": 56.559,
    "end": 60.879,
    "text": "anh chị nhớ là chúng ta phải hít thở sâu",
    "textdich": ""
  },
  {
    "start": 58.47,
    "end": 60.879,
    "text": "",
    "textdich": ""
  },
  {
    "start": 58.48,
    "end": 63.8,
    "text": "và thả nỏng tâm trí. Kiên trì chúng ta",
    "textdich": ""
  },
  {
    "start": 60.869,
    "end": 63.8,
    "text": "",
    "textdich": ""
  },
  {
    "start": 60.879,
    "end": 65.96,
    "text": "làm từ 7 cho tới 10 ngày là thấy cơ thể",
    "textdich": ""
  },
  {
    "start": 63.79,
    "end": 65.96,
    "text": "",
    "textdich": ""
  },
  {
    "start": 63.8,
    "end": 68.32,
    "text": "của chúng ta sẽ thay đổi rất là nhiều.",
    "textdich": ""
  },
  {
    "start": 65.95,
    "end": 68.32,
    "text": "",
    "textdich": ""
  },
  {
    "start": 65.96,
    "end": 70.88,
    "text": "Và cái bài thứ hai đó là chúng ta sẽ xòe",
    "textdich": ""
  },
  {
    "start": 68.31,
    "end": 70.88,
    "text": "",
    "textdich": ""
  },
  {
    "start": 68.32,
    "end": 72.88,
    "text": "tay hình chữ xuyên làm nóng đường kinh,",
    "textdich": ""
  },
  {
    "start": 70.87,
    "end": 72.88,
    "text": "",
    "textdich": ""
  },
  {
    "start": 70.88,
    "end": 74.68,
    "text": "khớp linh hoạt hơn. Động tác này nghe",
    "textdich": ""
  },
  {
    "start": 72.87,
    "end": 74.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 72.88,
    "end": 76.56,
    "text": "thì đơn giản nhưng khi mà chúng ta tác",
    "textdich": ""
  },
  {
    "start": 74.67,
    "end": 76.56,
    "text": "",
    "textdich": ""
  },
  {
    "start": 74.68,
    "end": 78.479,
    "text": "động mạnh đấy, khi mà xòe rộng hai tay",
    "textdich": ""
  },
  {
    "start": 76.55,
    "end": 78.479,
    "text": "",
    "textdich": ""
  },
  {
    "start": 76.56,
    "end": 81.0,
    "text": "theo hình trừ xuyên thì cơ thể của chúng",
    "textdich": ""
  },
  {
    "start": 78.469,
    "end": 81.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 78.479,
    "end": 83.119,
    "text": "ta như được mỡ van năng lượng, khí huyết",
    "textdich": ""
  },
  {
    "start": 80.99,
    "end": 83.119,
    "text": "",
    "textdich": ""
  },
  {
    "start": 81.0,
    "end": 85.52,
    "text": "nó sẽ lưu thông tốt hơn, khớp vai, khớp",
    "textdich": ""
  },
  {
    "start": 83.109,
    "end": 85.52,
    "text": "",
    "textdich": ""
  },
  {
    "start": 83.119,
    "end": 88.0,
    "text": "nưng sẽ giảm căng cứng. Những người hay",
    "textdich": ""
  },
  {
    "start": 85.51,
    "end": 88.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 85.52,
    "end": 90.36,
    "text": "bị tê bì, mỏi vai gáy vào buổi tối tập",
    "textdich": ""
  },
  {
    "start": 87.99,
    "end": 90.36,
    "text": "",
    "textdich": ""
  },
  {
    "start": 88.0,
    "end": 92.799,
    "text": "luyện thì rất là hợp, nhịp thở đều, tay",
    "textdich": ""
  },
  {
    "start": 90.35,
    "end": 92.799,
    "text": "",
    "textdich": ""
  },
  {
    "start": 90.36,
    "end": 95.0,
    "text": "mở rộng và cột sống của chúng ta thì giữ",
    "textdich": ""
  },
  {
    "start": 92.789,
    "end": 95.0,
    "text": "",
    "textdich": ""
  },
  {
    "start": 92.799,
    "end": 96.92,
    "text": "thăng bằng là đủ. Cách làm đấy thì các",
    "textdich": ""
  },
  {
    "start": 94.99,
    "end": 96.92,
    "text": "",
    "textdich": ""
  },
  {
    "start": 95.0,
    "end": 99.119,
    "text": "cô chú, anh chị đứng thẳng  hai",
    "textdich": ""
  },
  {
    "start": 96.91,
    "end": 99.119,
    "text": "",
    "textdich": ""
  },
  {
    "start": 96.92,
    "end": 103.159,
    "text": "chân rộng bằng vai và chúng ta sẽ dùng",
    "textdich": ""
  },
  {
    "start": 99.109,
    "end": 103.159,
    "text": "",
    "textdich": ""
  },
  {
    "start": 99.119,
    "end": 104.64,
    "text": "tay chúng ta sẽ đưa lên trên. xoay vòng.",
    "textdich": ""
  },
  {
    "start": 103.149,
    "end": 104.64,
    "text": "",
    "textdich": ""
  },
  {
    "start": 103.159,
    "end": 106.759,
    "text": "Các cô chú,  anh chị làm mỗi",
    "textdich": ""
  },
  {
    "start": 104.63,
    "end": 106.759,
    "text": "",
    "textdich": ""
  },
  {
    "start": 104.64,
    "end": 108.92,
    "text": "một lần làm vài chục cái, mỗi ngày chúng",
    "textdich": ""
  },
  {
    "start": 106.749,
    "end": 108.92,
    "text": "",
    "textdich": ""
  },
  {
    "start": 106.759,
    "end": 111.119,
    "text": "ta làm 6 70 cái thì cơ thể của chúng ta",
    "textdich": ""
  },
  {
    "start": 108.91,
    "end": 111.119,
    "text": "",
    "textdich": ""
  },
  {
    "start": 108.92,
    "end": 113.36,
    "text": "sẽ thay đổi rất nhiều. Chú ý khi làm thì",
    "textdich": ""
  },
  {
    "start": 111.109,
    "end": 113.36,
    "text": "",
    "textdich": ""
  },
  {
    "start": 111.119,
    "end": 115.24,
    "text": "chúng ta phải hít thở đều và giữ cho tâm",
    "textdich": ""
  },
  {
    "start": 113.35,
    "end": 115.24,
    "text": "",
    "textdich": ""
  },
  {
    "start": 113.36,
    "end": 116.64,
    "text": "trạng của chúng ta được thả nóng. Với",
    "textdich": ""
  },
  {
    "start": 115.23,
    "end": 116.64,
    "text": "",
    "textdich": ""
  },
  {
    "start": 115.24,
    "end": 118.28,
    "text": "những các cái động tác này sẽ giúp cho",
    "textdich": ""
  },
  {
    "start": 116.63,
    "end": 118.28,
    "text": "",
    "textdich": ""
  },
  {
    "start": 116.64,
    "end": 121.079,
    "text": "cơ thể của cô chú, anh chị khỏe mạnh lên",
    "textdich": ""
  },
  {
    "start": 118.27,
    "end": 121.079,
    "text": "",
    "textdich": ""
  },
  {
    "start": 118.28,
    "end": 123.719,
    "text": "từng ngày. Bài thứ ba là bài Hoàn Dương",
    "textdich": ""
  },
  {
    "start": 121.069,
    "end": 123.719,
    "text": "",
    "textdich": ""
  },
  {
    "start": 121.079,
    "end": 125.68,
    "text": "Trang, bí quyết giúp đi vững, đứng chắc",
    "textdich": ""
  },
  {
    "start": 123.709,
    "end": 125.68,
    "text": "",
    "textdich": ""
  },
  {
    "start": 123.719,
    "end": 127.56,
    "text": "khi về tà. Và đây chính là một cái phần",
    "textdich": ""
  },
  {
    "start": 125.67,
    "end": 127.56,
    "text": "",
    "textdich": ""
  },
  {
    "start": 125.68,
    "end": 129.599,
    "text": "quan trọng. Sau cái tuổi 40 đấy thì cơ",
    "textdich": ""
  },
  {
    "start": 127.55,
    "end": 129.599,
    "text": "",
    "textdich": ""
  },
  {
    "start": 127.56,
    "end": 131.4,
    "text": "thể của chúng ta bắt đầu thoái hóa, cơ",
    "textdich": ""
  },
  {
    "start": 129.589,
    "end": 131.4,
    "text": "",
    "textdich": ""
  },
  {
    "start": 129.599,
    "end": 133.52,
    "text": "khớp của chúng ta sẽ yếu nhanh. Và bài",
    "textdich": ""
  },
  {
    "start": 131.39,
    "end": 133.52,
    "text": "",
    "textdich": ""
  },
  {
    "start": 131.4,
    "end": 135.84,
    "text": "tập Hoàn Dương Trang sẽ giúp chúng ta",
    "textdich": ""
  },
  {
    "start": 133.51,
    "end": 135.84,
    "text": "",
    "textdich": ""
  },
  {
    "start": 133.52,
    "end": 138.12,
    "text": "cũng cố cổ chân, hông này rồi là cột",
    "textdich": ""
  },
  {
    "start": 135.83,
    "end": 138.12,
    "text": "",
    "textdich": ""
  },
  {
    "start": 135.84,
    "end": 140.519,
    "text": "sống, cải thiện thăng bằng và giãm các",
    "textdich": ""
  },
  {
    "start": 138.11,
    "end": 140.519,
    "text": "",
    "textdich": ""
  },
  {
    "start": 138.12,
    "end": 142.76,
    "text": "cái nguy cơ té ngã. Các cô chú, anh chị",
    "textdich": ""
  },
  {
    "start": 140.509,
    "end": 142.76,
    "text": "",
    "textdich": ""
  },
  {
    "start": 140.519,
    "end": 144.84,
    "text": "sẽ đứng tự nhiên, hai chân của chúng ta",
    "textdich": ""
  },
  {
    "start": 142.75,
    "end": 144.84,
    "text": "",
    "textdich": ""
  },
  {
    "start": 142.76,
    "end": 147.44,
    "text": "thì rộng bằng vai, đầu gối của chúng ta",
    "textdich": ""
  },
  {
    "start": 144.83,
    "end": 147.44,
    "text": "",
    "textdich": ""
  },
  {
    "start": 144.84,
    "end": 149.84,
    "text": "thì hơi khụỵ xuống, nưng thì thẳng, hít",
    "textdich": ""
  },
  {
    "start": 147.43,
    "end": 149.84,
    "text": "",
    "textdich": ""
  },
  {
    "start": 147.44,
    "end": 152.48,
    "text": "sâu, thả nỏng toàn thân. Từ từ chúng ta",
    "textdich": ""
  },
  {
    "start": 149.83,
    "end": 152.48,
    "text": "",
    "textdich": ""
  },
  {
    "start": 149.84,
    "end": 154.16,
    "text": "sẽ đưa hai tay lên theo nhịp thở. Sau",
    "textdich": ""
  },
  {
    "start": 152.47,
    "end": 154.16,
    "text": "",
    "textdich": ""
  },
  {
    "start": 152.48,
    "end": 156.72,
    "text": "đấy thì chúng ta lại hạ hai tay xuống",
    "textdich": ""
  },

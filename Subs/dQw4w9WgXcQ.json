  {
    "start": 18.64,
    "end": 21.88,
    "text": "♪ We're no strangers to love ♪",
    "textdich": ""
  },
  {
    "start": 22.64,
    "end": 26.96,
    "text": "♪ You know the rules\nand so do I ♪",
    "textdich": ""
  },
  {
    "start": 27.04,
    "end": 31.04,
    "text": "♪ A full commitment's\nwhat I'm thinking of ♪",
    "textdich": ""
  },
  {
    "start": 31.12,
    "end": 35.08,
    "text": "♪ You wouldn't get this\nfrom any other guy ♪",
    "textdich": ""
  },
  {
    "start": 35.16,
    "end": 39.52,
    "text": "♪ I just wanna tell you\nhow I'm feeling ♪",
    "textdich": ""
  },
  {
    "start": 40.52,
    "end": 42.92,
    "text": "♪ Gotta make you understand ♪",
    "textdich": ""
  },
  {
    "start": 43.0,
    "end": 45.12,
    "text": "♪ Never gonna give you up ♪",
    "textdich": ""
  },
  {
    "start": 45.2,

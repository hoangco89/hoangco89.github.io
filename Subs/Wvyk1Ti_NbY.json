[
  {
    "start": 0.16,
    "end": 5.92,
    "text": "",
    "textdich": ""
  },
  {
    "start": 1.92,
    "end": 10.4,
    "text": "Chào mừng đến với kênh English Daily Channel.",
    "textdich": ""
  },
  {
    "start": 5.92,
    "end": 15.92,
    "text": "Tom, trông cậu có vẻ lo lắng.  Chuyện gì đã xảy ra thế?",
    "textdich": ""
  },
  {
    "start": 10.4,
    "end": 19.279,
    "text": "Ashley, tôi đang gặp vấn đề.  Một vấn đề lớn.",
    "textdich": ""
  },
  {
    "start": 15.92,
    "end": 21.279,
    "text": "Được rồi, nói cho tôi biết đó là gì?",
    "textdich": ""
  },
  {
    "start": 19.279,
    "end": 24.16,
    "text": "Tôi ra ngoài",
    "textdich": ""
  },
  {
    "start": 21.279,
    "end": 28.56,
    "text": "và quên chìa khóa.",
    "textdich": ""
  },
  {
    "start": 24.16,
    "end": 33.52,
    "text": "Bạn quên chìa khóa rồi à?  Ôi không.  Vâng, tôi",
    "textdich": ""
  },
  {
    "start": 28.56,
    "end": 37.12,
    "text": "đã đóng cửa rồi.  Giờ thì chìa khóa đã ở bên trong rồi.",
    "textdich": ""
  },
  {
    "start": 33.52,
    "end": 40.719,
    "text": "Ồ, bạn tự khóa mình ở ngoài rồi.",
    "textdich": ""
  },
  {
    "start": 37.12,
    "end": 42.32,
    "text": "Đúng vậy, tôi bị khóa cửa ngoài.  Và tình hình còn tồi",
    "textdich": ""
  },
  {
    "start": 40.719,
    "end": 45.52,
    "text": "tệ hơn.",
    "textdich": ""
  },
  {
    "start": 42.32,
    "end": 49.12,
    "text": "Tệ hơn?  Ý anh là gì?",
    "textdich": ""
  },
  {
    "start": 45.52,
    "end": 52.48,
    "text": "Điện thoại của tôi cũng ở bên trong.",
    "textdich": ""
  },
  {
    "start": 49.12,
    "end": 56.96,
    "text": "Không có chìa khóa và không có điện thoại.",
    "textdich": ""
  },
  {
    "start": 52.48,
    "end": 59.039,
    "text": "Chính xác.  Tôi không thể mở cửa.  Tôi không thể",
    "textdich": ""
  },
  {
    "start": 56.96,
    "end": 61.359,
    "text": "gọi cho ai cả.",
    "textdich": ""
  },
  {
    "start": 59.039,
    "end": 65.519,
    "text": "Còn người bạn cùng phòng của bạn thì sao?",
    "textdich": ""
  },
  {
    "start": 61.359,
    "end": 70.4,
    "text": "Anh ấy sẽ quay lại tối nay.  Đã rất muộn.",
    "textdich": ""
  },
  {
    "start": 65.519,
    "end": 73.84,
    "text": "Vậy nên, bạn không thể vào cho đến tối nay.",
    "textdich": ""
  },
  {
    "start": 70.4,
    "end": 78.08,
    "text": "Đúng.  Tôi nên làm gì?",
    "textdich": ""
  },
  {
    "start": 73.84,
    "end": 80.0,
    "text": "Vậy là bạn có một ngày nghỉ rồi.",
    "textdich": ""
  },
  {
    "start": 78.08,
    "end": 85.36,
    "text": "Ngày nghỉ?",
    "textdich": ""
  },
  {
    "start": 80.0,
    "end": 90.24,
    "text": "Tôi cảm thấy lo lắng.  Không có điện thoại, không có chìa khóa.",
    "textdich": ""
  },
  {
    "start": 85.36,
    "end": 93.119,
    "text": "Đừng lo lắng.  Có lẽ đây là một điều tốt.",
    "textdich": ""
  },
  {
    "start": 90.24,
    "end": 97.2,
    "text": "Một điều tốt?  Thật sự?",
    "textdich": ""
  },
  {
    "start": 93.119,
    "end": 98.88,
    "text": "Đúng.  Bạn có thể thử một ngày không dùng",
    "textdich": ""
  },
  {
    "start": 97.2,
    "end": 102.64,
    "text": "điện thoại.",
    "textdich": ""
  },
  {
    "start": 98.88,
    "end": 104.079,
    "text": "Một ngày không có điện thoại.  Nghe có vẻ",
    "textdich": ""
  },
  {
    "start": 102.64,
    "end": 108.72,
    "text": "đáng sợ.",
    "textdich": ""
  },
  {
    "start": 104.079,
    "end": 110.399,
    "text": "Nó có thể rất thú vị.  Chúng ta có thể ra ngoài.  Chúng ta có thể nhìn thấy",
    "textdich": ""
  },
  {
    "start": 108.72,
    "end": 114.799,
    "text": "mọi thứ.",
    "textdich": ""
  },
  {
    "start": 110.399,
    "end": 118.159,
    "text": "Đi ra ngoài.  Chúng ta có thể đi đâu?",
    "textdich": ""
  },
  {
    "start": 114.799,
    "end": 120.479,
    "text": "Chúng ta hãy bắt đầu với thư viện.",
    "textdich": ""
  },
  {
    "start": 118.159,
    "end": 124.079,
    "text": "Thư viện.",
    "textdich": ""
  },
  {
    "start": 120.479,
    "end": 126.479,
    "text": "Được rồi.  Nhưng làm sao chúng ta có thể đi được?",
    "textdich": ""
  },
  {
    "start": 124.079,
    "end": 130.479,
    "text": "Chúng ta có thể đi xe buýt.   Xe buýt à",
    "textdich": ""
  },
  {
    "start": 126.479,
    "end": 132.0,
    "text": "?  Nhưng tôi cần Uber.  Tôi cần",
    "textdich": ""
  },
  {
    "start": 130.479,
    "end": 136.959,
    "text": "điện thoại của mình.",
    "textdich": ""
  },
  {
    "start": 132.0,
    "end": 141.92,
    "text": "Không phải hôm nay.  Hôm nay chúng ta đi xe buýt.",
    "textdich": ""
  },
  {
    "start": 136.959,
    "end": 145.04,
    "text": "Được rồi, chúng ta cùng thử nhé.  Không điện thoại, không chìa khóa, chỉ có",
    "textdich": ""
  },
  {
    "start": 141.92,
    "end": 149.44,
    "text": "xe buýt.  Chúng",
    "textdich": ""
  },
  {
    "start": 145.04,
    "end": 151.12,
    "text": "ta đã đến nơi rồi.  Đây là điểm dừng xe buýt đến",
    "textdich": ""
  },
  {
    "start": 149.44,
    "end": 154.319,
    "text": "thư viện.   Trạm",
    "textdich": ""
  },
  {
    "start": 151.12,
    "end": 158.8,
    "text": "xe buýt đến thư viện.",
    "textdich": ""
  },
  {
    "start": 154.319,
    "end": 161.68,
    "text": "Vâng, chúng tôi đợi xe buýt ở đây.",
    "textdich": ""
  },
  {
    "start": 158.8,
    "end": 166.16,
    "text": "Được rồi, chúng ta sẽ đợi ở đây.",
    "textdich": ""
  },
  {
    "start": 161.68,
    "end": 169.28,
    "text": "Nhìn kìa, xe buýt đang đến.   Tốt",
    "textdich": ""
  },
  {
    "start": 166.16,
    "end": 174.08,
    "text": ".  Tôi bắt đầu cảm thấy lo lắng.",
    "textdich": ""
  },
  {
    "start": 169.28,
    "end": 176.4,
    "text": "Tại sao lại lo lắng?  Vì nếu không có điện thoại, tôi",
    "textdich": ""
  },
  {
    "start": 174.08,
    "end": 180.959,
    "text": "không biết giờ giấc.",
    "textdich": ""
  },
  {
    "start": 176.4,
    "end": 184.8,
    "text": "Đúng vậy, không có điện thoại nghĩa là không có đồng hồ.   Phải.",
    "textdich": ""
  },
  {
    "start": 180.959,
    "end": 186.319,
    "text": "Tôi thường kiểm tra giờ xe buýt trên điện",
    "textdich": ""
  },
  {
    "start": 184.8,
    "end": 189.92,
    "text": "thoại.",
    "textdich": ""
  },
  {
    "start": 186.319,
    "end": 191.599,
    "text": "Hôm nay bạn sẽ học một cách khác.   Một",
    "textdich": ""
  },
  {
    "start": 189.92,
    "end": 196.879,
    "text": "cách khác.",
    "textdich": ""
  },
  {
    "start": 191.599,
    "end": 200.48,
    "text": "Đúng.  Hãy nhìn vào biển báo trạm xe buýt.",
    "textdich": ""
  },
  {
    "start": 196.879,
    "end": 201.76,
    "text": "Hãy nhìn vào biển báo trạm xe buýt.",
    "textdich": ""
  },
  {
    "start": 200.48,
    "end": 205.68,
    "text": "Được rồi,",
    "textdich": ""
  },
  {
    "start": 201.76,
    "end": 208.72,
    "text": "giờ thì lên xe buýt thôi.",
    "textdich": ""
  },
  {
    "start": 205.68,
    "end": 212.08,
    "text": "Được rồi, chúng ta bắt đầu thôi.   Hãy",
    "textdich": ""
  },
  {
    "start": 208.72,
    "end": 213.519,
    "text": "nói, \"Cho tôi một vé vào thư viện",
    "textdich": ""
  },
  {
    "start": 212.08,
    "end": 217.12,
    "text": ".\"",
    "textdich": ""
  },
  {
    "start": 213.519,
    "end": 220.959,
    "text": "Cho tôi một vé vào thư viện.",
    "textdich": ""
  },
  {
    "start": 217.12,
    "end": 225.44,
    "text": "Hoàn hảo.  Nào, cầm lấy vé đi.   Hiểu rồi",
    "textdich": ""
  },
  {
    "start": 220.959,
    "end": 231.92,
    "text": ".  Một vé vào thư viện.   Tốt",
    "textdich": ""
  },
  {
    "start": 225.44,
    "end": 234.319,
    "text": ".  Giờ thì chúng ta nên ngồi ở đâu?  Ừm.  Ở đây",
    "textdich": ""
  },
  {
    "start": 231.92,
    "end": 237.04,
    "text": "hay gần cửa sổ?",
    "textdich": ""
  },
  {
    "start": 234.319,
    "end": 240.72,
    "text": "Tôi thích chỗ ngồi cạnh cửa sổ.",
    "textdich": ""
  },
  {
    "start": 237.04,
    "end": 243.92,
    "text": "Được rồi, chúng ta ngồi gần cửa sổ nhé.",
    "textdich": ""
  },
  {
    "start": 240.72,
    "end": 245.76,
    "text": "Tuyệt vời.  Ngồi xuống.   Được rồi",
    "textdich": ""
  },
  {
    "start": 243.92,
    "end": 249.519,
    "text": ".   Ồ",
    "textdich": ""
  },
  {
    "start": 245.76,
    "end": 252.0,
    "text": ".  Cảm giác thật lạ.   Lạ",
    "textdich": ""
  },
  {
    "start": 249.519,
    "end": 256.56,
    "text": "lùng?  Tại sao?",
    "textdich": ""
  },
  {
    "start": 252.0,
    "end": 258.4,
    "text": "Vì mọi người đều đang dùng điện thoại, còn tôi thì",
    "textdich": ""
  },
  {
    "start": 256.56,
    "end": 259.44,
    "text": "không có điện thoại.",
    "textdich": ""
  },
  {
    "start": 258.4,
    "end": 263.68,
    "text": "Đúng.",
    "textdich": ""
  },
  {
    "start": 259.44,
    "end": 266.8,
    "text": "Nhiều người chỉ chăm chú nhìn vào điện thoại.",
    "textdich": ""
  },
  {
    "start": 263.68,
    "end": 268.16,
    "text": "Tôi cảm thấy hơi lo lắng.  Tôi nên",
    "textdich": ""
  },
  {
    "start": 266.8,
    "end": 270.08,
    "text": "làm gì?",
    "textdich": ""
  },
  {
    "start": 268.16,
    "end": 271.52,
    "text": "Hãy nhìn ra ngoài.",
    "textdich": ""
  },
  {
    "start": 270.08,
    "end": 276.8,
    "text": "Hãy nhìn ra ngoài.",
    "textdich": ""
  },
  {
    "start": 271.52,
    "end": 280.8,
    "text": "Đúng.  Hãy nhìn những hàng cây, những tòa nhà.",
    "textdich": ""
  },
  {
    "start": 276.8,
    "end": 284.24,
    "text": "Được rồi.  Ồ, cảnh đẹp quá.",
    "textdich": ""
  },
  {
    "start": 280.8,
    "end": 288.479,
    "text": "Tốt hơn màn hình nhỏ, phải không?",
    "textdich": ""
  },
  {
    "start": 284.24,
    "end": 293.44,
    "text": "Đúng.  Tốt hơn màn hình nhỏ.  Thấy chưa,",
    "textdich": ""
  },
  {
    "start": 288.479,
    "end": 297.12,
    "text": "không cần điện thoại, bạn vẫn có thể nhìn thấy cả thế giới.",
    "textdich": ""
  },
  {
    "start": 293.44,
    "end": 302.32,
    "text": "Khám phá thế giới?  Tôi thích điều đó.",
    "textdich": ""
  },
  {
    "start": 297.12,
    "end": 306.639,
    "text": "Và bạn cũng có thể nói chuyện với tôi.",
    "textdich": ""
  },
  {
    "start": 302.32,
    "end": 310.72,
    "text": "Đúng.  Tôi sẽ nói chuyện với bạn, chứ không phải với điện thoại.",
    "textdich": ""
  },
  {
    "start": 306.639,
    "end": 311.919,
    "text": "Nhớ nhé, chúng ta xuống ở",
    "textdich": ""
  },
  {
    "start": 310.72,
    "end": 315.84,
    "text": "trạm dừng thư viện.",
    "textdich": ""
  },
  {
    "start": 311.919,
    "end": 318.4,
    "text": "Chúng ta xuống ở trạm dừng gần thư viện, đúng không?",
    "textdich": ""
  },
  {
    "start": 315.84,
    "end": 321.84,
    "text": "Đúng.  Đúng vậy.",
    "textdich": ""
  },
  {
    "start": 318.4,
    "end": 323.28,
    "text": "Được rồi.  Điểm dừng thư viện.  Đừng để tôi",
    "textdich": ""
  },
  {
    "start": 321.84,
    "end": 326.8,
    "text": "bỏ lỡ cơ hội này.",
    "textdich": ""
  },
  {
    "start": 323.28,
    "end": 332.0,
    "text": "Đừng lo lắng.  Tôi sẽ nói cho bạn biết.   Tốt",
    "textdich": ""
  },
  {
    "start": 326.8,
    "end": 334.24,
    "text": ".  Không có điện thoại, tôi cảm thấy lạc lõng, nhưng",
    "textdich": ""
  },
  {
    "start": 332.0,
    "end": 338.16,
    "text": "đồng thời cũng tự do.",
    "textdich": ""
  },
  {
    "start": 334.24,
    "end": 342.639,
    "text": "Lạc lối và tự do.  Điều đó thật thú vị.",
    "textdich": ""
  },
  {
    "start": 338.16,
    "end": 346.8,
    "text": "Đúng.  Đây là điều mới mẻ đối với tôi, nhưng có lẽ nó sẽ",
    "textdich": ""
  },
  {
    "start": 342.639,
    "end": 350.72,
    "text": "tốt.  Hôm nay bạn sẽ học được điều gì đó.",
    "textdich": ""
  },
  {
    "start": 346.8,
    "end": 353.28,
    "text": "Đúng.  Một ngày không có điện thoại cũng không",
    "textdich": ""
  },
  {
    "start": 350.72,
    "end": 357.52,
    "text": "tệ lắm.   Chúng",
    "textdich": ""
  },
  {
    "start": 353.28,
    "end": 362.24,
    "text": "ta đã đến nơi rồi.  Đây là thư viện.",
    "textdich": ""
  },
  {
    "start": 357.52,
    "end": 366.96,
    "text": "Ồ, nó to và rất yên tĩnh.",
    "textdich": ""
  },
  {
    "start": 362.24,
    "end": 368.319,
    "text": "Đúng vậy, đây là một nơi yên tĩnh để đọc sách và",
    "textdich": ""
  },
  {
    "start": 366.96,
    "end": 371.68,
    "text": "học tập.",
    "textdich": ""
  },
  {
    "start": 368.319,
    "end": 373.199,
    "text": "Đọc và học tập.",
    "textdich": ""
  },
  {
    "start": 371.68,
    "end": 378.16,
    "text": "Không gây tiếng ồn,",
    "textdich": ""
  },
  {
    "start": 373.199,
    "end": 379.919,
    "text": "phải không?  Không có tiếng ồn.  Mọi người đến đây để",
    "textdich": ""
  },
  {
    "start": 378.16,
    "end": 383.759,
    "text": "tập trung.",
    "textdich": ""
  },
  {
    "start": 379.919,
    "end": 385.28,
    "text": "Tập trung.  Ý bạn là hãy chú ý.",
    "textdich": ""
  },
  {
    "start": 383.759,
    "end": 389.039,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 385.28,
    "end": 392.96,
    "text": "Hãy chú ý và học hỏi.",
    "textdich": ""
  },
  {
    "start": 389.039,
    "end": 396.4,
    "text": "Được rồi.  Tôi cũng sẽ cố gắng tập trung.   Tốt",
    "textdich": ""
  },
  {
    "start": 392.96,
    "end": 400.319,
    "text": ".  Chúng ta vào trong thôi.   Được rồi",
    "textdich": ""
  },
  {
    "start": 396.4,
    "end": 404.8,
    "text": ".  Bên trong thư viện.",
    "textdich": ""
  },
  {
    "start": 400.319,
    "end": 408.639,
    "text": "Nhìn kìa, nhiều sách quá!",
    "textdich": ""
  },
  {
    "start": 404.8,
    "end": 409.6,
    "text": "Vâng, rất nhiều.  Tôi không biết phải",
    "textdich": ""
  },
  {
    "start": 408.639,
    "end": 413.52,
    "text": "bắt đầu từ đâu.",
    "textdich": ""
  },
  {
    "start": 409.6,
    "end": 416.56,
    "text": "Chúng ta hãy cùng tìm hiểu về nấu ăn.",
    "textdich": ""
  },
  {
    "start": 413.52,
    "end": 421.28,
    "text": "Nấu ăn trong thư viện?",
    "textdich": ""
  },
  {
    "start": 416.56,
    "end": 422.8,
    "text": "Đúng vậy, có sách về mọi thứ.",
    "textdich": ""
  },
  {
    "start": 421.28,
    "end": 427.68,
    "text": "Mọi thứ?",
    "textdich": ""
  },
  {
    "start": 422.8,
    "end": 430.639,
    "text": "Ý bạn là cả việc nấu ăn nữa à?  Đúng.  Nấu ăn,",
    "textdich": ""
  },
  {
    "start": 427.68,
    "end": 432.4,
    "text": "du lịch, lịch sử,",
    "textdich": ""
  },
  {
    "start": 430.639,
    "end": 437.599,
    "text": "tất cả mọi thứ.   Ồ",
    "textdich": ""
  },
  {
    "start": 432.4,
    "end": 441.84,
    "text": ".  Không chỉ tiểu thuyết.  Điều đó thật mới mẻ đối với tôi.",
    "textdich": ""
  },
  {
    "start": 437.599,
    "end": 445.919,
    "text": "Để tôi lấy một cuốn sách xuống.",
    "textdich": ""
  },
  {
    "start": 441.84,
    "end": 449.039,
    "text": "Được rồi.  Một cuốn sách về nấu ăn.",
    "textdich": ""
  },
  {
    "start": 445.919,
    "end": 453.36,
    "text": "Chúng ta hãy ngồi đây cạnh cửa sổ.   Chiếc",
    "textdich": ""
  },
  {
    "start": 449.039,
    "end": 457.44,
    "text": "bàn đẹp.  Ánh nắng mặt trời ấm áp.",
    "textdich": ""
  },
  {
    "start": 453.36,
    "end": 461.84,
    "text": "Đúng.  Cảm giác thật thoải mái.   Thoải",
    "textdich": ""
  },
  {
    "start": 457.44,
    "end": 466.24,
    "text": "mái?  Ý bạn là vừa ngon vừa dễ ăn phải không?",
    "textdich": ""
  },
  {
    "start": 461.84,
    "end": 468.96,
    "text": "Chính xác.  Tốt và dễ.   Được rồi",
    "textdich": ""
  },
  {
    "start": 466.24,
    "end": 470.24,
    "text": ".  Tôi thích nơi thoải mái này",
    "textdich": ""
  },
  {
    "start": 468.96,
    "end": 474.639,
    "text": ".",
    "textdich": ""
  },
  {
    "start": 470.24,
    "end": 476.4,
    "text": "Bây giờ, hãy nhìn vào trang này.  Nó mô tả một",
    "textdich": ""
  },
  {
    "start": 474.639,
    "end": 477.919,
    "text": "công thức nấu ăn.",
    "textdich": ""
  },
  {
    "start": 476.4,
    "end": 480.72,
    "text": "Công thức.",
    "textdich": ""
  },
  {
    "start": 477.919,
    "end": 485.36,
    "text": "Đó là kế hoạch về thực phẩm, phải không?",
    "textdich": ""
  },
  {
    "start": 480.72,
    "end": 490.319,
    "text": "Đúng.  Kế hoạch về thực phẩm.  Một công thức nấu ăn.",
    "textdich": ""
  },
  {
    "start": 485.36,
    "end": 495.12,
    "text": "Được rồi, tôi muốn đọc công thức nấu ăn thật chậm.",
    "textdich": ""
  },
  {
    "start": 490.319,
    "end": 496.8,
    "text": "Ashley, cái này đẹp đấy.  Tôi có thể đọc sách mà không cần",
    "textdich": ""
  },
  {
    "start": 495.12,
    "end": 502.24,
    "text": "điện thoại.",
    "textdich": ""
  },
  {
    "start": 496.8,
    "end": 504.639,
    "text": "Như bạn thấy đấy, sách có thể cung cấp đầy đủ thông tin.",
    "textdich": ""
  },
  {
    "start": 502.24,
    "end": 507.12,
    "text": "Thông tin đầy đủ,",
    "textdich": ""
  },
  {
    "start": 504.639,
    "end": 513.839,
    "text": "chứ không chỉ là những mẩu thông tin rời rạc,",
    "textdich": ""
  },
  {
    "start": 507.12,
    "end": 516.479,
    "text": "đúng không?  Không phải những mảnh nhỏ.  Đầy đủ và rõ ràng.",
    "textdich": ""
  },
  {
    "start": 513.839,
    "end": 518.159,
    "text": "Tôi cảm thấy bình tĩnh.",
    "textdich": ""
  },
  {
    "start": 516.479,
    "end": 523.519,
    "text": "Rất bình tĩnh.",
    "textdich": ""
  },
  {
    "start": 518.159,
    "end": 529.44,
    "text": "Đúng vậy, thư viện giúp bạn thư thái.",
    "textdich": ""
  },
  {
    "start": 523.519,
    "end": 532.64,
    "text": "Giờ tôi rất thích đọc sách.  Tôi rất thích nó.   Tuyệt",
    "textdich": ""
  },
  {
    "start": 529.44,
    "end": 534.399,
    "text": "vời, Tom.  Bạn đã thấy",
    "textdich": ""
  },
  {
    "start": 532.64,
    "end": 540.399,
    "text": "sự khác biệt chưa?",
    "textdich": ""
  },
  {
    "start": 534.399,
    "end": 542.24,
    "text": "Vâng, tôi hiểu rồi.  Không điện thoại, chỉ có sách.",
    "textdich": ""
  },
  {
    "start": 540.399,
    "end": 546.56,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 542.24,
    "end": 551.6,
    "text": "Không điện thoại, chỉ có sách.",
    "textdich": ""
  },
  {
    "start": 546.56,
    "end": 553.2,
    "text": "Chúng ta đọc rất nhiều sách, Tom ạ.  Bạn có cảm thấy mắt",
    "textdich": ""
  },
  {
    "start": 551.6,
    "end": 556.959,
    "text": "mệt mỏi không?",
    "textdich": ""
  },
  {
    "start": 553.2,
    "end": 561.04,
    "text": "Vâng, hơi mệt một chút.",
    "textdich": ""
  },
  {
    "start": 556.959,
    "end": 566.16,
    "text": "Vậy thì hãy cho mắt nghỉ ngơi đi.   Cho",
    "textdich": ""
  },
  {
    "start": 561.04,
    "end": 567.68,
    "text": "mắt nghỉ ngơi chút nào?  Ý bạn là ngừng đọc à?",
    "textdich": ""
  },
  {
    "start": 566.16,
    "end": 570.88,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 567.68,
    "end": 572.64,
    "text": "Chúng ta ra ngoài chơi nhé.",
    "textdich": ""
  },
  {
    "start": 570.88,
    "end": 573.839,
    "text": "Bên ngoài ở",
    "textdich": ""
  },
  {
    "start": 572.64,
    "end": 579.04,
    "text": "đâu?   Bãi",
    "textdich": ""
  },
  {
    "start": 573.839,
    "end": 581.12,
    "text": "biển.  Chúng ta có thể nhìn ra biển rất xa.",
    "textdich": ""
  },
  {
    "start": 579.04,
    "end": 583.12,
    "text": "Biển ư?   Nghe hay đấy",
    "textdich": ""
  },
  {
    "start": 581.12,
    "end": 587.6,
    "text": ".",
    "textdich": ""
  },
  {
    "start": 583.12,
    "end": 589.839,
    "text": "Đúng vậy, biển sẽ giúp bạn thư giãn.",
    "textdich": ""
  },
  {
    "start": 587.6,
    "end": 593.8,
    "text": "Được rồi,",
    "textdich": ""
  },
  {
    "start": 589.839,
    "end": 593.8,
    "text": "chúng ta đi biển thôi.",
    "textdich": ""
  },
  {
    "start": 593.839,
    "end": 603.6,
    "text": "Chúng ta đến rồi, Tom.  Đây là bãi biển.",
    "textdich": ""
  },
  {
    "start": 598.8,
    "end": 607.68,
    "text": "Ôi, biển rộng lớn quá.",
    "textdich": ""
  },
  {
    "start": 603.6,
    "end": 612.32,
    "text": "Vâng, nó rộng rãi và thoáng đãng.",
    "textdich": ""
  },
  {
    "start": 607.68,
    "end": 617.04,
    "text": "Rộng mở và thoáng đãng.  Tôi thích điều đó.",
    "textdich": ""
  },
  {
    "start": 612.32,
    "end": 622.0,
    "text": "Hãy nhìn những con sóng.  Họ không bao giờ ngừng lại.",
    "textdich": ""
  },
  {
    "start": 617.04,
    "end": 626.079,
    "text": "Những con sóng không bao giờ ngừng lại.  Luôn luôn chuyển động.   Phải.",
    "textdich": ""
  },
  {
    "start": 622.0,
    "end": 627.92,
    "text": "Biển cả tràn đầy sức sống.",
    "textdich": ""
  },
  {
    "start": 626.079,
    "end": 631.04,
    "text": "Còn sống.",
    "textdich": ""
  },
  {
    "start": 627.92,
    "end": 632.56,
    "text": "Ý bạn là nó không bao giờ ngủ?",
    "textdich": ""
  },
  {
    "start": 631.04,
    "end": 635.12,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 632.56,
    "end": 639.279,
    "text": "Nó không bao giờ ngủ.   Tôi",
    "textdich": ""
  },
  {
    "start": 635.12,
    "end": 642.16,
    "text": "thấy điều này thật mới lạ.  Tôi thường chỉ xem",
    "textdich": ""
  },
  {
    "start": 639.279,
    "end": 646.079,
    "text": "ảnh trên điện thoại.",
    "textdich": ""
  },
  {
    "start": 642.16,
    "end": 647.76,
    "text": "Giờ bạn có thể nhìn thấy bằng mắt chứ không phải qua",
    "textdich": ""
  },
  {
    "start": 646.079,
    "end": 652.16,
    "text": "màn hình nữa.",
    "textdich": ""
  },
  {
    "start": 647.76,
    "end": 655.44,
    "text": "Đúng vậy, tôi nhìn bằng mắt thường, chứ không phải qua màn hình.",
    "textdich": ""
  },
  {
    "start": 652.16,
    "end": 659.76,
    "text": "Chúng ta cùng ngồi đây trên cát nhé.",
    "textdich": ""
  },
  {
    "start": 655.44,
    "end": 662.56,
    "text": "Được rồi.  Cát ở đây mềm mại.",
    "textdich": ""
  },
  {
    "start": 659.76,
    "end": 665.839,
    "text": "Mềm mại và ấm áp.",
    "textdich": ""
  },
  {
    "start": 662.56,
    "end": 670.32,
    "text": "Đúng.  Mềm mại và ấm áp.   Cởi giày ra",
    "textdich": ""
  },
  {
    "start": 665.839,
    "end": 675.12,
    "text": ".  Cảm thấy tốt hơn.   Được rồi",
    "textdich": ""
  },
  {
    "start": 670.32,
    "end": 679.839,
    "text": ".  Ồ.  Cảm giác thật tuyệt.",
    "textdich": ""
  },
  {
    "start": 675.12,
    "end": 681.36,
    "text": "Nhìn thấy?  Không có điện thoại.  Chỉ có biển và",
    "textdich": ""
  },
  {
    "start": 679.839,
    "end": 685.68,
    "text": "cát.",
    "textdich": ""
  },
  {
    "start": 681.36,
    "end": 690.24,
    "text": "Không có điện thoại.  Chỉ có biển và cát.",
    "textdich": ""
  },
  {
    "start": 685.68,
    "end": 694.24,
    "text": "Hãy nhìn những người đó.  Họ chụp ảnh.",
    "textdich": ""
  },
  {
    "start": 690.24,
    "end": 696.88,
    "text": "Đúng.  Nhiều bức ảnh được chụp bằng điện thoại của họ.",
    "textdich": ""
  },
  {
    "start": 694.24,
    "end": 699.6,
    "text": "Nhưng chúng ta không cần điều đó.",
    "textdich": ""
  },
  {
    "start": 696.88,
    "end": 704.32,
    "text": "Chúng tôi không có.  Tại sao không?",
    "textdich": ""
  },
  {
    "start": 699.6,
    "end": 707.6,
    "text": "Vì chúng ta ghi nhớ bằng trái tim.",
    "textdich": ""
  },
  {
    "start": 704.32,
    "end": 709.279,
    "text": "Hãy nhớ bằng trái tim, chứ không phải bằng",
    "textdich": ""
  },
  {
    "start": 707.6,
    "end": 710.88,
    "text": "hình ảnh.",
    "textdich": ""
  },
  {
    "start": 709.279,
    "end": 714.88,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 710.88,
    "end": 717.92,
    "text": "Ký ức còn quý hơn cả hình ảnh.",
    "textdich": ""
  },
  {
    "start": 714.88,
    "end": 721.279,
    "text": "Có lẽ bạn nói đúng.",
    "textdich": ""
  },
  {
    "start": 717.92,
    "end": 724.0,
    "text": "Mặt trời đang lặn.",
    "textdich": ""
  },
  {
    "start": 721.279,
    "end": 728.8,
    "text": "Màu sắc thật đẹp.",
    "textdich": ""
  },
  {
    "start": 724.0,
    "end": 732.56,
    "text": "Đúng.  Bầu trời rực rỡ sắc cam và hồng.",
    "textdich": ""
  },
  {
    "start": 728.8,
    "end": 736.16,
    "text": "Màu cam và hồng.  Tôi thích nó.",
    "textdich": ""
  },
  {
    "start": 732.56,
    "end": 738.079,
    "text": "Hãy lắng nghe tiếng sóng vỗ.   Thật yên",
    "textdich": ""
  },
  {
    "start": 736.16,
    "end": 739.839,
    "text": "bình.",
    "textdich": ""
  },
  {
    "start": 738.079,
    "end": 742.72,
    "text": "Rất bình tĩnh.",
    "textdich": ""
  },
  {
    "start": 739.839,
    "end": 746.079,
    "text": "Bạn cảm thấy thư giãn chưa?",
    "textdich": ""
  },
  {
    "start": 742.72,
    "end": 748.16,
    "text": "Vâng, rất thoải mái.",
    "textdich": ""
  },
  {
    "start": 746.079,
    "end": 752.88,
    "text": "Tôi không hề nhớ điện thoại của mình.   Tuyệt",
    "textdich": ""
  },
  {
    "start": 748.16,
    "end": 755.92,
    "text": "vời!  Bạn thấy đấy, hoàn toàn có thể có một ngày không dùng",
    "textdich": ""
  },
  {
    "start": 752.88,
    "end": 759.6,
    "text": "điện thoại.",
    "textdich": ""
  },
  {
    "start": 755.92,
    "end": 762.399,
    "text": "Vâng, điều đó hoàn toàn khả thi và hòa bình.   \"",
    "textdich": ""
  },
  {
    "start": 759.6,
    "end": 764.56,
    "text": "Yên bình\" là từ thích hợp nhất.",
    "textdich": ""
  },
  {
    "start": 762.399,
    "end": 766.16,
    "text": "Tôi cảm thấy tự do.",
    "textdich": ""
  },
  {
    "start": 764.56,
    "end": 768.8,
    "text": "Hoàn toàn miễn phí.",
    "textdich": ""
  },
  {
    "start": 766.16,
    "end": 772.0,
    "text": "Tự do và hạnh phúc.",
    "textdich": ""
  },
  {
    "start": 768.8,
    "end": 775.76,
    "text": "Đúng.  Tự do và hạnh phúc.",
    "textdich": ""
  },
  {
    "start": 772.0,
    "end": 779.6,
    "text": "Hãy tận hưởng khoảnh khắc này.",
    "textdich": ""
  },
  {
    "start": 775.76,
    "end": 783.44,
    "text": "Đúng.  Hãy tận hưởng khoảnh khắc này.",
    "textdich": ""
  },
  {
    "start": 779.6,
    "end": 787.6,
    "text": "Mặt trời đang lặn rồi, Tom à.",
    "textdich": ""
  },
  {
    "start": 783.44,
    "end": 790.16,
    "text": "Đúng.  Bầu trời giờ đã chuyển sang màu cam.   Trời",
    "textdich": ""
  },
  {
    "start": 787.6,
    "end": 792.16,
    "text": "đã tối.  Bạn có muốn làm",
    "textdich": ""
  },
  {
    "start": 790.16,
    "end": 794.399,
    "text": "việc khác không?",
    "textdich": ""
  },
  {
    "start": 792.16,
    "end": 799.2,
    "text": "Một điều khác nữa.",
    "textdich": ""
  },
  {
    "start": 794.399,
    "end": 801.519,
    "text": "Như cái gì?  Chúng ta cùng đi xem phim nhé.   Rạp chiếu",
    "textdich": ""
  },
  {
    "start": 799.2,
    "end": 803.839,
    "text": "phim.",
    "textdich": ""
  },
  {
    "start": 801.519,
    "end": 809.04,
    "text": "Một bộ phim chiếu rạp.",
    "textdich": ""
  },
  {
    "start": 803.839,
    "end": 811.76,
    "text": "Đúng.  Màn hình lớn, chứ không phải điện thoại nhỏ.",
    "textdich": ""
  },
  {
    "start": 809.04,
    "end": 814.639,
    "text": "H.",
    "textdich": ""
  },
  {
    "start": 811.76,
    "end": 816.72,
    "text": "Điều đó khác.   Nghe có",
    "textdich": ""
  },
  {
    "start": 814.639,
    "end": 820.399,
    "text": "vẻ thú vị đấy.",
    "textdich": ""
  },
  {
    "start": 816.72,
    "end": 822.639,
    "text": "Tuyệt vời.  Chúng ta đi xem phim nhé.",
    "textdich": ""
  },
  {
    "start": 820.399,
    "end": 826.6,
    "text": "Được rồi.",
    "textdich": ""
  },
  {
    "start": 822.639,
    "end": 826.6,
    "text": "Chúng ta cùng đi xem phim nhé.",
    "textdich": ""
  },
  {
    "start": 826.8,
    "end": 836.24,
    "text": "Chúng ta đến rồi, Tom.  Đây là rạp chiếu phim.",
    "textdich": ""
  },
  {
    "start": 831.76,
    "end": 841.199,
    "text": "Trông nó rất lớn với nhiều đèn bên trong.",
    "textdich": ""
  },
  {
    "start": 836.24,
    "end": 845.839,
    "text": "Đúng.  Khu vực này được gọi là sảnh chờ.",
    "textdich": ""
  },
  {
    "start": 841.199,
    "end": 851.279,
    "text": "Sảnh.  Ý bạn là sảnh vào phải không?",
    "textdich": ""
  },
  {
    "start": 845.839,
    "end": 855.92,
    "text": "Chính xác.  Địa điểm trước rạp hát.",
    "textdich": ""
  },
  {
    "start": 851.279,
    "end": 860.24,
    "text": "Ồ, có rất nhiều áp phích phim trên tường.",
    "textdich": ""
  },
  {
    "start": 855.92,
    "end": 862.0,
    "text": "Đúng vậy, áp phích cho biết những bộ phim nào đang",
    "textdich": ""
  },
  {
    "start": 860.24,
    "end": 866.959,
    "text": "chiếu.   \"",
    "textdich": ""
  },
  {
    "start": 862.0,
    "end": 871.6,
    "text": "Đang phát\" ở đây có nghĩa là trình chiếu ngay bây giờ hoặc sớm thôi.   Phải.",
    "textdich": ""
  },
  {
    "start": 866.959,
    "end": 875.36,
    "text": "Đang chiếu hoặc sẽ chiếu trong thời gian rất ngắn.",
    "textdich": ""
  },
  {
    "start": 871.6,
    "end": 881.36,
    "text": "Và bạn đã có sẵn hai vé cho chúng tôi rồi à?",
    "textdich": ""
  },
  {
    "start": 875.36,
    "end": 885.68,
    "text": "Vâng, hai vé.  Chúng tôi đã sẵn sàng lên đường.",
    "textdich": ""
  },
  {
    "start": 881.36,
    "end": 887.199,
    "text": "Được rồi, chúng ta vào trong tìm",
    "textdich": ""
  },
  {
    "start": 885.68,
    "end": 890.399,
    "text": "chỗ ngồi nhé.",
    "textdich": ""
  },
  {
    "start": 887.199,
    "end": 891.839,
    "text": "Ở đây trời tối, ngay cả trước khi phim",
    "textdich": ""
  },
  {
    "start": 890.399,
    "end": 895.36,
    "text": "bắt đầu.",
    "textdich": ""
  },
  {
    "start": 891.839,
    "end": 896.88,
    "text": "Đúng vậy, màn ảnh rộng lúc nào cũng tối",
    "textdich": ""
  },
  {
    "start": 895.36,
    "end": 901.76,
    "text": ".",
    "textdich": ""
  },
  {
    "start": 896.88,
    "end": 906.48,
    "text": "Wow, bên trong có nhiều chỗ ngồi quá.   Ghế",
    "textdich": ""
  },
  {
    "start": 901.76,
    "end": 910.0,
    "text": "của chúng tôi ở hàng thứ sáu, ở giữa.",
    "textdich": ""
  },
  {
    "start": 906.48,
    "end": 911.36,
    "text": "Hàng thứ sáu, ở giữa.  Nghe hay đấy",
    "textdich": ""
  },
  {
    "start": 910.0,
    "end": 916.639,
    "text": ".",
    "textdich": ""
  },
  {
    "start": 911.36,
    "end": 920.88,
    "text": "Ngồi đây.  Chúng ta có thể nhìn thấy màn hình rõ ràng.",
    "textdich": ""
  },
  {
    "start": 916.639,
    "end": 924.72,
    "text": "Cảnh đẹp.  Ý bạn là một bức ảnh rõ nét?",
    "textdich": ""
  },
  {
    "start": 920.88,
    "end": 926.32,
    "text": "Vâng, hình ảnh từ vị trí này rất rõ nét",
    "textdich": ""
  },
  {
    "start": 924.72,
    "end": 931.12,
    "text": ".",
    "textdich": ""
  },
  {
    "start": 926.32,
    "end": 935.44,
    "text": "Wow, màn hình trông thật lớn.",
    "textdich": ""
  },
  {
    "start": 931.12,
    "end": 940.16,
    "text": "Lớn hơn nhiều so với điện thoại hoặc tivi.",
    "textdich": ""
  },
  {
    "start": 935.44,
    "end": 944.639,
    "text": "Vâng, tôi cảm thấy mình thật nhỏ bé khi đứng trước màn hình lớn.",
    "textdich": ""
  },
  {
    "start": 940.16,
    "end": 949.6,
    "text": "Nghe này, Tom, phim bắt đầu chiếu rồi.",
    "textdich": ""
  },
  {
    "start": 944.639,
    "end": 953.519,
    "text": "Ôi, âm thanh to và mạnh quá.",
    "textdich": ""
  },
  {
    "start": 949.6,
    "end": 954.959,
    "text": "Đúng vậy, bạn sẽ có cảm giác như đang ở trong",
    "textdich": ""
  },
  {
    "start": 953.519,
    "end": 958.32,
    "text": "câu chuyện vậy.",
    "textdich": ""
  },
  {
    "start": 954.959,
    "end": 959.839,
    "text": "Âm thanh to và mạnh mẽ, không giống như",
    "textdich": ""
  },
  {
    "start": 958.32,
    "end": 964.399,
    "text": "chiếc điện thoại nhỏ của tôi,",
    "textdich": ""
  },
  {
    "start": 959.839,
    "end": 967.839,
    "text": "phải không?  Điện thoại này quá nhỏ và yếu.",
    "textdich": ""
  },
  {
    "start": 964.399,
    "end": 969.36,
    "text": "Hình ảnh rất sáng.  Tôi để ý đến từng",
    "textdich": ""
  },
  {
    "start": 967.839,
    "end": 974.32,
    "text": "chi tiết.",
    "textdich": ""
  },
  {
    "start": 969.36,
    "end": 978.56,
    "text": "Vâng, màn hình lớn rất rõ nét.",
    "textdich": ""
  },
  {
    "start": 974.32,
    "end": 982.959,
    "text": "Điều này thật thú vị.  Tôi rất thích nó.   Tốt",
    "textdich": ""
  },
  {
    "start": 978.56,
    "end": 986.88,
    "text": ".  Giờ bạn đã có thể tận hưởng rạp chiếu phim rồi.",
    "textdich": ""
  },
  {
    "start": 982.959,
    "end": 992.56,
    "text": "Đúng.  Xem nhiều hơn là xem trên điện thoại.   Bạn",
    "textdich": ""
  },
  {
    "start": 986.88,
    "end": 998.0,
    "text": "thấy đấy, xem phim ở rạp là một trải nghiệm đặc biệt.",
    "textdich": ""
  },
  {
    "start": 992.56,
    "end": 1002.399,
    "text": "Đúng.  Đặc biệt và tuyệt vời.  Tôi thích nó.",
    "textdich": ""
  },
  {
    "start": 998.0,
    "end": 1006.72,
    "text": "Hãy cùng ngồi xuống và thưởng thức câu chuyện.",
    "textdich": ""
  },
  {
    "start": 1002.399,
    "end": 1010.72,
    "text": "Đúng.  Chúng ta hãy cùng nhau tận hưởng nhé.",
    "textdich": ""
  },
  {
    "start": 1006.72,
    "end": 1012.88,
    "text": "Bộ phim đã hoàn thành.  Tom, cậu có",
    "textdich": ""
  },
  {
    "start": 1010.72,
    "end": 1018.399,
    "text": "thích không?",
    "textdich": ""
  },
  {
    "start": 1012.88,
    "end": 1020.8,
    "text": "Vâng, tôi rất thích nó.  Màn ảnh rộng thật",
    "textdich": ""
  },
  {
    "start": 1018.399,
    "end": 1024.24,
    "text": "tuyệt vời.",
    "textdich": ""
  },
  {
    "start": 1020.8,
    "end": 1029.52,
    "text": "Tôi rất vui vì bạn thích nó.",
    "textdich": ""
  },
  {
    "start": 1024.24,
    "end": 1032.079,
    "text": "Bây giờ chúng tôi đang đi bộ về nhà.  Thành phố trông",
    "textdich": ""
  },
  {
    "start": 1029.52,
    "end": 1036.4,
    "text": "khác hẳn vào ban đêm.",
    "textdich": ""
  },
  {
    "start": 1032.079,
    "end": 1038.959,
    "text": "Đúng vậy, đèn đường làm cho mọi thứ trở nên",
    "textdich": ""
  },
  {
    "start": 1036.4,
    "end": 1042.079,
    "text": "dịu nhẹ và ấm áp,",
    "textdich": ""
  },
  {
    "start": 1038.959,
    "end": 1043.6,
    "text": "và những tòa nhà cao tầng cũng rực rỡ",
    "textdich": ""
  },
  {
    "start": 1042.079,
    "end": 1049.2,
    "text": "ánh đèn.",
    "textdich": ""
  },
  {
    "start": 1043.6,
    "end": 1054.32,
    "text": "Thành phố vẫn tràn đầy sức sống ngay cả về đêm.",
    "textdich": ""
  },
  {
    "start": 1049.2,
    "end": 1058.64,
    "text": "Cảm giác đi bộ mà không mang theo điện thoại thật thư thái.",
    "textdich": ""
  },
  {
    "start": 1054.32,
    "end": 1060.64,
    "text": "Đúng vậy, bạn có thể quan sát được nhiều hơn khi tay",
    "textdich": ""
  },
  {
    "start": 1058.64,
    "end": 1067.44,
    "text": "được tự do.",
    "textdich": ""
  },
  {
    "start": 1060.64,
    "end": 1069.36,
    "text": "Hôm nay tôi đã nhìn thấy nhiều hơn và cũng suy nghĩ nhiều hơn.",
    "textdich": ""
  },
  {
    "start": 1067.44,
    "end": 1074.72,
    "text": "Như cái gì?",
    "textdich": ""
  },
  {
    "start": 1069.36,
    "end": 1078.48,
    "text": "Cuộc sống vẫn có thể trọn vẹn mà không cần điện thoại.",
    "textdich": ""
  },
  {
    "start": 1074.72,
    "end": 1082.88,
    "text": "Đó là một ý kiến ​​rất hay.",
    "textdich": ""
  },
  {
    "start": 1078.48,
    "end": 1085.2,
    "text": "Sáng nay tôi hơi lo lắng, nhưng giờ thì tôi đã",
    "textdich": ""
  },
  {
    "start": 1082.88,
    "end": 1090.08,
    "text": "cảm thấy bình tĩnh rồi.",
    "textdich": ""
  },
  {
    "start": 1085.2,
    "end": 1095.28,
    "text": "Như vậy, ngày của bạn đã thay đổi từng bước một.",
    "textdich": ""
  },
  {
    "start": 1090.08,
    "end": 1098.16,
    "text": "Đúng.  Thư viện, bãi biển, rạp chiếu phim,",
    "textdich": ""
  },
  {
    "start": 1095.28,
    "end": 1101.84,
    "text": "tất cả đều không cần điện thoại.",
    "textdich": ""
  },
  {
    "start": 1098.16,
    "end": 1103.12,
    "text": "Và bạn đã làm rất tốt.  Một ngày trọn vẹn không có",
    "textdich": ""
  },
  {
    "start": 1101.84,
    "end": 1106.799,
    "text": "nó.",
    "textdich": ""
  },
  {
    "start": 1103.12,
    "end": 1111.52,
    "text": "Đúng.  Và tôi cảm thấy tự hào.",
    "textdich": ""
  },
  {
    "start": 1106.799,
    "end": 1117.039,
    "text": "Bạn nên tự hào.  Bạn đã học được rất nhiều điều.",
    "textdich": ""
  },
  {
    "start": 1111.52,
    "end": 1118.559,
    "text": "Tôi đã học được rất nhiều điều.  Ý bạn là giống như tiếng Anh à?",
    "textdich": ""
  },
  {
    "start": 1117.039,
    "end": 1121.76,
    "text": "Chính xác.",
    "textdich": ""
  },
  {
    "start": 1118.559,
    "end": 1124.24,
    "text": "Bạn đã thực hành tiếng Anh trong",
    "textdich": ""
  },
  {
    "start": 1121.76,
    "end": 1128.16,
    "text": "các tình huống thực tế.",
    "textdich": ""
  },
  {
    "start": 1124.24,
    "end": 1132.559,
    "text": "Trên xe buýt, trong thư viện,",
    "textdich": ""
  },
  {
    "start": 1128.16,
    "end": 1138.559,
    "text": "trên bãi biển và trong rạp chiếu phim.",
    "textdich": ""
  },
  {
    "start": 1132.559,
    "end": 1143.039,
    "text": "Đúng.  Bốn địa điểm, bốn trải nghiệm,",
    "textdich": ""
  },
  {
    "start": 1138.559,
    "end": 1144.48,
    "text": "và tôi lặp đi lặp lại những từ mới",
    "textdich": ""
  },
  {
    "start": 1143.039,
    "end": 1146.08,
    "text": ".   Phải",
    "textdich": ""
  },
  {
    "start": 1144.48,
    "end": 1150.08,
    "text": "?",
    "textdich": ""
  },
  {
    "start": 1146.08,
    "end": 1153.679,
    "text": "Việc lặp lại làm cho lời nói trở nên mạnh mẽ hơn.",
    "textdich": ""
  },
  {
    "start": 1150.08,
    "end": 1158.16,
    "text": "Tôi cảm thấy tự tin hơn bây giờ.   Tốt",
    "textdich": ""
  },
  {
    "start": 1153.679,
    "end": 1159.76,
    "text": ".  Sự tự tin là món quà tuyệt vời nhất mà",
    "textdich": ""
  },
  {
    "start": 1158.16,
    "end": 1163.36,
    "text": "ngày hôm nay mang lại.   Ít dùng",
    "textdich": ""
  },
  {
    "start": 1159.76,
    "end": 1166.0,
    "text": "điện thoại hơn, học tập nhiều hơn.",
    "textdich": ""
  },
  {
    "start": 1163.36,
    "end": 1166.0,
    "text": "Tôi thích",
    "textdich": ""
  }
]